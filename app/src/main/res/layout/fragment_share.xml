<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F6F2"
    tools:context=".ShareFragment">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvArchivos"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingStart="6dp"
        android:paddingTop="6dp"
        android:paddingEnd="6dp"
        android:paddingBottom="96dp"
        tools:listitem="@layout/item_foto_simple" />

    <androidx.constraintlayout.motion.widget.MotionLayout
        android:id="@+id/fabMotionLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layoutDescription="@xml/share_fab_scene">

        <View
            android:id="@+id/fabOverlay"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:alpha="0"
            android:background="#14000000"
            android:visibility="visible"
            android:elevation="1dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

<!--        <View-->
<!--            android:id="@+id/background"-->
<!--            android:layout_width="360dp"-->
<!--            android:layout_height="360dp"-->
<!--            android:background="@drawable/bg_circle_menu"-->
<!--            android:alpha="0"-->
<!--            android:visibility="visible"-->
<!--            android:elevation="2dp"-->
<!--            app:layout_constraintBottom_toBottomOf="@id/fabMain"-->
<!--            app:layout_constraintEnd_toEndOf="@id/fabMain"-->
<!--            app:layout_constraintStart_toStartOf="@id/fabMain"-->
<!--            app:layout_constraintTop_toTopOf="@id/fabMain" />-->

        <LinearLayout
            android:id="@+id/actionActualizar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="visible"
            android:alpha="0"
            android:elevation="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="160dp"
            android:layout_marginBottom="55dp">

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabActualizar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="Actualizar"
                app:backgroundTint="#5C8A64"
                app:fabCustomSize="52dp"
                app:srcCompat="@android:drawable/ic_popup_sync"
                app:tint="@android:color/white" />

            <TextView
                android:id="@+id/txtActualizar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Actualizar"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/actionCarpeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="visible"
            android:alpha="0"
            android:elevation="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="100dp"
            android:layout_marginBottom="95dp">

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabCarpeta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="Carpeta"
                app:backgroundTint="#5C8A64"
                app:fabCustomSize="52dp"
                app:srcCompat="@android:drawable/ic_menu_upload"
                app:tint="@android:color/white" />

            <TextView
                android:id="@+id/txtCarpeta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Carpeta"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/actionEnviar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="visible"
            android:alpha="0"
            android:elevation="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="22dp"
            android:layout_marginBottom="110dp">

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabEnviar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="Enviar"
                app:backgroundTint="#5C8A64"
                app:fabCustomSize="52dp"
                app:srcCompat="@android:drawable/ic_menu_send"
                app:tint="@android:color/white" />

            <TextView
                android:id="@+id/txtEnviar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Enviar"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabMain"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="18dp"
            android:layout_marginBottom="24dp"
            android:contentDescription="Opciones"
            android:elevation="10dp"
            android:visibility="visible"
            app:backgroundTint="@android:color/white"
            app:fabCustomSize="64dp"
            app:rippleColor="#22000000"
            app:srcCompat="@android:drawable/ic_input_add"
            app:tint="#2D6CDF"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.motion.widget.MotionLayout>


</FrameLayout>