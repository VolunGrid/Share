<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFF7FB"
    android:paddingHorizontal="20dp"
    android:paddingTop="20dp"
    android:paddingBottom="18dp"
    tools:context=".ScreenPermission">

    <!-- Zona superior decorativa -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="170dp"
        android:orientation="vertical"
        android:gravity="center"
        >

        <ImageView
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:src="@drawable/baseline_arrow_forward_ios_24"
            android:contentDescription="@string/app_name" />

    </LinearLayout>

    <!-- Título -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Comparte archivos"
        android:textAlignment="textStart"
        android:textColor="#1D1D1F"
        android:textSize="28sp"
        android:fontFamily="@font/montserrat_alternates_bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:paddingHorizontal="18dp"
        android:text="Envía fotos, videos, documentos y apps de forma rápida y segura entre dispositivos cercanos."
        android:textAlignment="textStart"
        android:textColor="#8A8A8A"
        android:textSize="14sp"
        android:lineSpacingExtra="2dp"
        android:fontFamily="@font/montserrat_alternates_regular" />

    <!-- Tarjeta principal -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="18dp"
        android:orientation="vertical"
        android:background="@drawable/bg_card_soft"
        android:padding="18dp">

        <!-- Item -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="top"
            android:paddingVertical="10dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginTop="2dp"
                android:src="@drawable/baseline_arrow_forward_ios_24"
                android:contentDescription="@null" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Transferencia rápida"
                    android:textColor="#1D1D1F"
                    android:textSize="16sp"
                    android:fontFamily="@font/montserrat_alternates_bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Comparte archivos en segundos con una conexión estable y simple."
                    android:textColor="#8A8A8A"
                    android:textSize="12sp"
                    android:fontFamily="@font/montserrat_alternates_regular" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="top"
            android:paddingVertical="10dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginTop="2dp"
                android:src="@drawable/baseline_arrow_forward_ios_24"
                android:contentDescription="@null" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Archivos grandes"
                    android:textColor="#1D1D1F"
                    android:textSize="16sp"
                    android:fontFamily="@font/montserrat_alternates_bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Envía videos, carpetas y documentos pesados sin complicaciones."
                    android:textColor="#8A8A8A"
                    android:textSize="12sp"
                    android:fontFamily="@font/montserrat_alternates_regular" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="top"
            android:paddingVertical="10dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginTop="2dp"
                android:src="@drawable/baseline_arrow_forward_ios_24"
                android:contentDescription="@null" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fotos, videos y apps"
                    android:textColor="#1D1D1F"
                    android:textSize="16sp"
                    android:fontFamily="@font/montserrat_alternates_bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Selecciona tu contenido favorito y compártelo fácilmente."
                    android:textColor="#8A8A8A"
                    android:textSize="12sp"
                    android:fontFamily="@font/montserrat_alternates_regular" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="top"
            android:paddingVertical="10dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginTop="2dp"
                android:src="@drawable/baseline_arrow_forward_ios_24"
                android:contentDescription="@null" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Entre dispositivos cercanos"
                    android:textColor="#1D1D1F"
                    android:textSize="16sp"
                    android:fontFamily="@font/montserrat_alternates_bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Conecta y comparte de forma segura con tus amigos cercanos."
                    android:textColor="#8A8A8A"
                    android:textSize="12sp"
                    android:fontFamily="@font/montserrat_alternates_regular" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btnContinuar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_button_pink"
            android:text="Continuar"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:fontFamily="@font/montserrat_alternates_bold" />
    </LinearLayout>

</LinearLayout>